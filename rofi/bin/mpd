#!/bin/bash

STYLE="pastel"

rofi_command="rofi -theme $STYLE/mpd.rasi"

# Gets the current status of mpd (for us to parse it later on)
status="$(mpc status)"
# Defines the Play / Pause option content
if [[ $status == *"[playing]"* ]]; then
  play_pause=""
else
  play_pause=""
fi
active=""
urgent=""

# Display if repeat mode is on / off
tog_repeat=""
if [[ $status == *"repeat: on"* ]]; then
    active="-a 5"
elif [[ $status == *"repeat: off"* ]]; then
    urgent="-u 5"
else
    tog_repeat=""
fi

tog_single=""
if [[ $status == *"single: on"* ]]; then
    [ -n "$active" ] && active+=",6" || active="-a 6"
elif [[ $status == *"single: off"* ]]; then
    [ -n "$urgent" ] && urgent+=",6" || urgent="-u 6"
else
    tog_single=""
fi

# Display if random mode is on / off
tog_random=""
if [[ $status == *"random: on"* ]]; then
    [ -n "$active" ] && active+=",7" || active="-a 7"
elif [[ $status == *"random: off"* ]]; then
    [ -n "$urgent" ] && urgent+=",7" || urgent="-u 7"
else
    tog_random=""
fi

stop=""
next=""
rewind=""
previous=""
music=""

# Variable passed to rofi
options="$play_pause\n$stop\n$previous\n$rewind\n$next\n$tog_repeat\n$tog_single\n$tog_random"

# Get the current playing song
current=$(mpc -f %title% current)
# If mpd isn't running it will return an empty string, we don't want to display that
if [[ -z "$current" ]]; then
    current="-"
fi

# Spawn the mpd menu with the "Play / Pause" entry selected by default
chosen="$(echo -e "$options" | $rofi_command -p "$current" -dmenu $active $urgent -selected-row 0)"
case $chosen in
    $rewind)
        mpc -q seek 0 && kunst --size 60x60 --silent
        ;;
    $previous)
        mpc -q prev && kunst --size 60x60 --silent
        ;;
    $play_pause)
        mpc -q toggle && kunst --size 60x60 --silent
        ;;
    $stop)
        mpc -q stop
        ;;
    $next)
        mpc -q next && kunst --size 60x60 --silent
        ;;
    $tog_repeat)
        mpc -q repeat
        ;;
    $tog_single)
        mpc -q single
        ;;
    $tog_random)
        mpc -q random
        ;;
esac
