#!/bin/bash

STYLE="theme"

rofi_command="rofi -theme $STYLE/screenshot.rasi"

# Options
screen="Ó¶¢"
area="Ó•í"
window="Ó¶à"

# Variable passed to rofi
options="$screen\n$area\n$window"

chosen="$(echo -e "$options" | $rofi_command -p 'Take A Shot' -dmenu -selected-row 1)"
case $chosen in
    $screen)
        sleep 0.5; flameshot screen -c
        ;;
    $area)
        flameshot gui
        ;;
    $window)
        flameshot full -c -p
        ;;
esac

