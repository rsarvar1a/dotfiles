    <keybind key="W-v">
      <action name="Execute">
        <command>tasks</command>
      </action>
    </keybind>
    <!-- Openbox -->
    <keybind key="C-S-R">
      <action name="Reconfigure"/>
    </keybind>
    <keybind key="W-Escape">
      <action name="Execute">
        <command>xkill</command>
      </action>
    </keybind>
    <keybind key="W-c">
      <action name="Close"/>
    </keybind>
    <keybind key="W-q">
      <action name="Execute">
        <command>/usr/local/bin/word-lookup.sh</command>
      </action>
    </keybind>
    <keybind key="A-F5">
      <action name="Iconify"/>
    </keybind>
    <keybind key="A-F6">
      <action name="ToggleMaximizeFull"/>
    </keybind>
    <keybind key="A-F7">
      <action name="ToggleDecorations"/>
    </keybind>
    <keybind key="A-F11">
      <action name="ToggleFullscreen"/>
    </keybind>
    <keybind key="W-d">
      <action name="ToggleShowDesktop"/>
    </keybind>
    <!-- Activate Move/Resize -->
    <keybind key="A-comma">
      <action name="Resize"/>
    </keybind>
    <keybind key="A-m">
