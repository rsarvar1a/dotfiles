      </action>
    </keybind>
    <keybind key="S-W-0">
      <action name="SendToDesktop">
        <desktop>10</desktop>
      </action>
    </keybind>
    <keybind key="C-S-W-1">
      <action name="SendToDesktop">
        <desktop>11</desktop>
      </action>
    </keybind>
    <keybind key="C-S-W-2">
      <action name="SendToDesktop">
        <desktop>12</desktop>
      </action>
    </keybind>
    <keybind key="C-S-W-3">
      <action name="SendToDesktop">
        <desktop>13</desktop>
      </action>
    </keybind>
    <keybind key="C-S-W-4">
      <action name="SendToDesktop">
        <desktop>14</desktop>
      </action>
    </keybind>
    <keybind key="C-S-W-5">
      <action name="SendToDesktop">
        <desktop>15</desktop>
      </action>
    </keybind>
    <!-- Switch b/w Applications -->
    <keybind key="A-Tab">
      <action name="NextWindow">
        <allDesktops>no</allDesktops>
        <raise>yes</raise>
        <!-- Hide black border around windows -->
        <bar>no</bar>
        <finalactions>
          <action name="Focus"/>
          <action name="UnshadeRaise"/>
        </finalactions>
      </action>
    </keybind>
    <keybind key="W-Tab">
      <action name="NextWindow">
        <allDesktops>yes</allDesktops>
        <!-- Hide black border around windows -->
        <bar>no</bar>
        <finalactions>
          <action name="focus"/>
          <action name="raise"/>
        </finalactions>
      </action>
    </keybind>
    <!-- Send Application to next/prev desktop -->
    <!-- Media Controls-->
    <keybind key="XF86AudioRaiseVolume">
      <action name="Execute">
        <command>volume-up</command>
      </action>
    </keybind>
    <keybind key="XF86AudioLowerVolume">
      <action name="Execute">
        <command>volume-down</command>
      </action>
    </keybind>
    <keybind key="XF86AudioMute">
      <action name="Execute">
        <command>amixer set Master toggle</command>
      </action>
    </keybind>
    <keybind key="XF86AudioStop">
      <action name="Execute">
        <command>mpc stop</command>
      </action>
    </keybind>
    <keybind key="XF86AudioPlay">
      <action name="Execute">
        <command>mpc toggle</command>
      </action>
    </keybind>
    <keybind key="XF86AudioPrev">
      <action name="Execute">
        <command>mpc prev</command>
      </action>
    </keybind>
    <keybind key="XF86AudioNext">
      <action name="Execute">
        <command>mpc next</command>
      </action>
    </keybind>
    <!-- Brightness Control -->
    <keybind key="XF86MonBrightnessUp">
      <action name="Execute">
        <command>backlight-up</command>
      </action>
    </keybind>
    <keybind key="XF86MonBrightnessDown">
      <action name="Execute">
        <command>backlight-down</command>
      </action>
    </keybind>
    <!-- Screenshot Keys -->
    <keybind key="S-Print">
      <action name="Execute">
        <command>shutter -s</command>
      </action>
    </keybind>
    <keybind key="A-Print">
      <action name="Execute">
        <command>shutter -a</command>
      </action>
    </keybind>
    <keybind key="C-Print">
      <action name="Execute">
        <command>shutter -f</command>
      </action>
    </keybind>
    <!-- Launch Applications -->
    <keybind key="W-e">
      <action name="Execute">
        <command>geany</command>
      </action>
    </keybind>
    <keybind key="W-f">
      <action name="ToggleMaximizeFull"/>
    </keybind>
    <keybind key="W-t">
      <action name="Execute">
        <command>kitty @ --to=unix:@kitty new-window --window-type=os</command>
      </action>
    </keybind>
    <keybind key="W-Return">
      <action name="Execute">
        <command>kitty @ --to=unix:@kitty new-window --window-type=os</command>
      </action>
    </keybind>
    <keybind key="W-w">
      <action name="Execute">
        <command>~/.config/rofi/bin/windows</command>
      </action>
    </keybind>
    <keybind key="W-n">
      <action name="Execute">
        <command>networkmanager_dmenu</command>
      </action>
    </keybind>
    <keybind key="A-F1">
      <action name="Execute">
        <command>~/.config/rofi/bin/launcher</command>
      </action>
    </keybind>
    <keybind key="W-S-y">
      <action name="Execute">
        <command>~/.config/rofi/bin/ytfzf</command>
      </action>
    </keybind>
    <keybind key="W-A-y">
      <action name="Execute">
        <command>~/.config/rofi/bin/ytfzfd</command>
      </action>
    </keybind>
    <!-- convenient rofi mirror -->
    <keybind key="W-m" chroot="true">
      <keybind key="Return">
        <action name="Execute">
          <command>~/.config/rofi/bin/mpd</command>
        </action>
      </keybind>
      <keybind key="Left">
        <action name="Execute">
          <command>mpc -q prev</command>
        </action>
      </keybind>
      <keybind key="Right">
        <action name="Execute">
          <command>mpc -q next</command>
        </action>
      </keybind>
      <keybind key="Down">
        <action name="Execute">
          <command>mpc -q seek 0</command>
        </action>
      </keybind>
      <keybind key="p">
        <action name="Execute">
          <command>mpc -q toggle</command>
        </action>
      </keybind>
      <keybind key="s">
        <action name="Execute">
          <command>mpc -q stop</command>
        </action>
      </keybind>
      <keybind key="y">
        <action name="Execute">
          <command>mpc -q single</command>
        </action>
      </keybind>
      <keybind key="z">
        <action name="Execute">
          <command>mpc -q random</command>
        </action>
      </keybind>
      <keybind key="r">
        <action name="Execute">
          <command>mpc -q repeat</command>
        </action>
      </keybind>
      <keybind key="Escape">
        <action name="BreakChroot"/>
      </keybind>
    </keybind>
    <!-- SPOTIFY VERSION -->
    <keybind key="W-comma">
      <keybind key="Return">
        <action name="Execute">
          <command>xdotool windowactive $(xdotool search --name 'spotify'))</command>
        </action>
      </keybind>
      <keybind key="Right">
        <action name="Execute">
          <command>playerctl --player=playerctld next</command>
        </action>
      </keybind>
      <keybind key="Left">
        <action name="Execute">
          <command>playerctl --player=playerctld previous</command>
        </action>
      </keybind>
      <keybind key="Down">
        <action name="Execute">
          <command>playerctl --player=playerctld previous</command>
        </action>
      </keybind>
      <keybind key="p">
        <action name="Execute">
          <command>playerctl --player=playerctld play-pause</command>
        </action>
      </keybind>
      <keybind key="s">
        <action name="Execute">
          <command>playerctl --player=playerctld stop</command>
        </action>
      </keybind>
      <keybind key="y">
        <action name="Execute">
          <command>playerctl --player=playerctld loop "Track"</command>
        </action>
      </keybind>
      <keybind key="z">
        <action name="Execute">
          <command>playerctl --player=playerctld shuffle "Toggle"</command>
        </action>
      </keybind>
      <keybind key="r">
        <action name="Execute">
          <command>playerctl --player=playerctld loop "Playlist"</command>
        </action>
      </keybind>
    </keybind>
    <keybind key="W-x">
      <action name="Execute">
        <command>~/.config/rofi/bin/powermenu</command>
      </action>
    </keybind>
    <keybind key="W-s">
      <action name="Execute">
        <command>~/.config/rofi/bin/screenshot</command>
