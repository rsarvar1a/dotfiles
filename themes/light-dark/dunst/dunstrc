[global]
monitor = 0
follow = mouse
indicate_hidden = yes
shrink = no
separator_height = 4
separator_color = auto
padding = 20
horizontal_padding = 20
frame_width = 1
sort = no
idle_threshold = 120
font = VictorMono Nerd Font 14
line_height = 4
markup = full
format = %s\n%b
alignment = left
show_age_threshold = 60
word_wrap = yes
ignore_newline = no
stack_duplicates = false
hide_duplicate_count = yes
show_indicators = no
icon_position = left
max_icon_size = 48
sticky_history = yes
history_length = 20
browser = x-www-browser -new-tab
always_run_script = true
title = Dunst
class = Dunst

width = 300
height = 300
origin = top-right
offset = 20x64

[urgency_low]
timeout = 2
background = "#D0D0D4"
foreground = "#303034"
frame_color = "#A071A6"

[urgency_normal]
timeout = 5
background = "#D0D0D4"
foreground = "#202024"
frame_color = "#A071A6"

[urgency_critical]
timeout = 0
background = "#D0D0D4"
foreground = "#DC2430"
frame_color = "#DC2430"
